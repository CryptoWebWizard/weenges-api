PORT=3000
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/weenggs_db

# Access token — min 64 random chars in production
JWT_SECRET=your_super_secret_key_min_64_chars
JWT_EXPIRES_IN=8h

# Refresh token — separate secret, longer TTL
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging level: error | warn | info | debug
LOG_LEVEL=info
